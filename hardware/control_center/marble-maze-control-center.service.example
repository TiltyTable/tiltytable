[Unit]
Description=Marble Maze Control Center
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pi
WorkingDirectory=%h/marble-maze
ExecStart=/usr/bin/env python3 %h/marble-maze/hardware/run_control_center.py --host 0.0.0.0 --port 8080
Restart=always
RestartSec=2

[Install]
WantedBy=multi-user.target
