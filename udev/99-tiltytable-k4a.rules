# Azure Kinect access and Jetson SuperSpeed stability.
# The tegra-xusb controller can lose the Kinect during U1/U2 transitions
# (USB protocol error -71), which makes libk4a fail reading the depth MCU BOS
# descriptor. Keep the Kinect composite devices active.

SUBSYSTEM=="usb", ATTR{idVendor}=="045e", ATTR{idProduct}=="097a", MODE="0666", GROUP="plugdev", ATTR{power/control}="on", ATTR{power/usb3_hardware_lpm_u1}="disabled", ATTR{power/usb3_hardware_lpm_u2}="disabled"
SUBSYSTEM=="usb", ATTR{idVendor}=="045e", ATTR{idProduct}=="097b", MODE="0666", GROUP="plugdev", ATTR{power/control}="on"
SUBSYSTEM=="usb", ATTR{idVendor}=="045e", ATTR{idProduct}=="097c", MODE="0666", GROUP="plugdev", ATTR{power/control}="on"
SUBSYSTEM=="usb", ATTR{idVendor}=="045e", ATTR{idProduct}=="097d", MODE="0666", GROUP="plugdev", ATTR{power/control}="on"
SUBSYSTEM=="usb", ATTR{idVendor}=="045e", ATTR{idProduct}=="097e", MODE="0666", GROUP="plugdev", ATTR{power/control}="on"
