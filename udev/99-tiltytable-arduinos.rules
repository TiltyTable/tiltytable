# Stable Arduino serial aliases for the tiltytable project.
# Install to /etc/udev/rules.d/99-tiltytable-arduinos.rules, then:
#   sudo udevadm control --reload-rules && sudo udevadm trigger
#
# Board roles:
#   Uno R3        -> /dev/arduino-stewart  (3-DOF UIM5756PM tilt platform)
#   Uno R4 Minima -> /dev/arduino-modules  (PCA9685 module servos + WS2812 LEDs)

SUBSYSTEM=="tty", ENV{ID_BUS}=="usb", ENV{ID_VENDOR_ID}=="2341", ENV{ID_MODEL_ID}=="0043", ENV{ID_SERIAL_SHORT}=="0353638323635150F080", SYMLINK+="arduino-stewart", MODE="0666", GROUP="plugdev"
SUBSYSTEM=="tty", ENV{ID_BUS}=="usb", ENV{ID_VENDOR_ID}=="2341", ENV{ID_MODEL_ID}=="0069", ENV{ID_SERIAL_SHORT}=="360D16233631323166E233334B572F27", SYMLINK+="arduino-modules", MODE="0666", GROUP="plugdev"
